{
  "name": "md-sync",
  "displayName": "MD Sync",
  "description": "MDSync provides a live Markdown preview with bidirectional cursor and scroll synchronization.",
  "version": "0.0.3",
  "publisher": "GauravSaroha",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pricekree/mdsync.git"
  },
  "homepage": "https://github.com/pricekree/mdsync",
  "bugs": {
    "url": "https://github.com/pricekree/mdsync/issues"
  },
  "keywords": [
    "markdown",
    "md",
    "markdown preview",
    "preview",
    "live preview",
    "scroll sync",
    "cursor sync",
    "documentation",
    "readme",
    "mdsync",
    "md-sync"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },

  "categories": [
    "Other"
  ],

  "activationEvents": [
    "onLanguage:markdown"
  ],

  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "mdsync.openPreview",
        "title": "MD Sync: Open Preview Side by Side",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdsync.openPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mdsync.openPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == markdown"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },

  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.4.0"
  },

  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1"
  },

  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}